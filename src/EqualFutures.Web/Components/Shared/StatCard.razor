<div class="ef-card ef-stat">
    <div class="label">@Label</div>
    <div class="value">@Value</div>
    @if (!string.IsNullOrEmpty(Sub))
    {
        <div class="sub">@Sub</div>
    }
    @if (Pill is not null)
    {
        <div style="margin-top:.5rem"><span class="ef-pill @PillClass">@Pill</span></div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
    [Parameter] public string? Sub { get; set; }
    [Parameter] public string? Pill { get; set; }
    [Parameter] public string PillClass { get; set; } = "good";
}
