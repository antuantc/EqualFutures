@page "/assets"
@attribute [Authorize]
@rendermode InteractiveServer
@inject PlanState State

<PageTitle>Assets &amp; Liabilities · EqualFutures</PageTitle>

<div class="ef-page-header">
    <h1>Assets &amp; Liabilities</h1>
    <p>Everything you own and owe. Balances feed the retirement and education projections.</p>
</div>

@if (!State.IsLoaded)
{
    <p>Loading…</p>
}
else
{
    var plan = State.Plan!;

    @if (!State.CanEdit)
    {
        <div class="ef-rec info" style="margin-bottom:1rem">
            <div class="rec-title">Read-only access</div>
            <div class="rec-detail">You can view this family's accounts but not change them.</div>
        </div>
    }

    <div class="ef-card" style="margin-bottom:1rem">
        <h2>Accounts &amp; assets</h2>
        <div class="ef-table-scroll">
        <table class="ef-table ef-table-cards">
            <thead>
                <tr>
                    <th>Name</th><th>Type</th><th>Group</th><th>Tax</th>
                    <th class="num">Balance</th><th class="num">Annual contribution</th><th>For child</th><th>For parent</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in plan.Accounts)
                {
                    <tr>
                        <td data-label="Name"><input class="form-control form-control-sm" @bind="a.Name" /></td>
                        <td data-label="Type">
                            <select class="form-select form-select-sm" @bind="a.Type">
                                @foreach (var t in Enum.GetValues<AccountType>())
                                {
                                    <option value="@t">@Humanize(t)</option>
                                }
                            </select>
                        </td>
                        <td data-label="Group">
                            <select class="form-select form-select-sm" @bind="a.Category">
                                @foreach (var g in GroupDisplayOrder)
                                {
                                    <option value="@g">@Humanize(g)</option>
                                }
                            </select>
                        </td>
                        <td data-label="Tax">
                            <select class="form-select form-select-sm" @bind="a.TaxTreatment">
                                @foreach (var tx in Enum.GetValues<TaxTreatment>())
                                {
                                    <option value="@tx">@Humanize(tx)</option>
                                }
                            </select>
                        </td>
                        <td class="num" data-label="Balance"><CurrencyInput @bind-Value="a.CurrentBalance" InputClass="form-control-sm" /></td>
                        <td class="num" data-label="Annual contribution"><CurrencyInput @bind-Value="a.AnnualContribution" InputClass="form-control-sm" /></td>
                        <td data-label="For child">
                            @if (CanAssignToChild(a))
                            {
                                <select class="form-select form-select-sm" @bind="a.BeneficiaryChildId">
                                    <option value="">—</option>
                                    @foreach (var c in plan.Children)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            }
                        </td>
                        <td data-label="For parent">
                            @if (CanAssignToParent(a))
                            {
                                <select class="form-select form-select-sm" @bind="a.OwnerParentId">
                                    <option value="">Joint</option>
                                    @foreach (var p in plan.Parents)
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                            }
                        </td>
                        <td data-label=""><button class="btn btn-sm btn-outline-danger" @onclick="() => plan.Accounts.Remove(a)">Remove</button></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        <button class="btn btn-outline-secondary" style="margin-top:.75rem" @onclick="AddAccount">+ Add account</button>
    </div>

    @if (plan.Accounts.Any(a => a.Category == AccountCategory.RealEstate))
    {
        <div class="ef-card" style="margin-bottom:1rem">
            <h2>Real estate details</h2>
            <p style="color:var(--ef-muted);font-size:.85rem;margin-top:-.5rem">
                Set how each property is used so it grows — and, for rentals, contributes income — correctly in your retirement projection.
            </p>
            @foreach (var re in plan.Accounts.Where(a => a.Category == AccountCategory.RealEstate))
            {
                <div class="ef-grid ef-grid-4 ef-edit-row">
                    <div class="ef-field">
                        <label>@re.Name</label>
                        <select class="form-select" @bind="re.Use">
                            <option value="@RealEstateUse.PrimaryResidence">Primary residence</option>
                            <option value="@RealEstateUse.Rental">Rental / cash-flow property</option>
                        </select>
                    </div>
                    <div class="ef-field">
                        <label>Secured by</label>
                        <select class="form-select" @bind="re.SecuredByLiabilityId">
                            <option value="">No mortgage</option>
                            @foreach (var l in plan.Liabilities.Where(l => l.Type == LiabilityType.Mortgage))
                            {
                                <option value="@l.Id">@l.Name</option>
                            }
                        </select>
                    </div>
                    @if (re.Use == RealEstateUse.Rental)
                    {
                        <div class="ef-field">
                            <label>Monthly rent</label>
                            <CurrencyInput Value="@(re.MonthlyRentToday ?? 0m)" ValueChanged="@(v => re.MonthlyRentToday = v)" />
                        </div>
                        <div class="ef-field">
                            <label>Vacancy rate: @((re.VacancyRate * 100).ToString("0.#"))%</label>
                            <input type="range" class="form-range" min="0" max="0.3" step="0.01" @bind="re.VacancyRate" @bind:event="oninput" />
                        </div>
                        <div class="ef-field">
                            <label>Monthly operating expenses</label>
                            <CurrencyInput @bind-Value="re.MonthlyOperatingExpenses" />
                        </div>
                        <div class="ef-field">
                            <label>Capital expenditure reserve: @((re.AnnualCapExReservePercent * 100).ToString("0.#"))%/yr</label>
                            <input type="range" class="form-range" min="0" max="0.03" step="0.0025" @bind="re.AnnualCapExReservePercent" @bind:event="oninput" />
                        </div>
                    }
                </div>
            }
        </div>
    }

    <div class="ef-card" style="margin-bottom:1rem">
        <h2>Liabilities</h2>
        <div class="ef-table-scroll">
        <table class="ef-table ef-table-cards">
            <thead>
                <tr><th>Name</th><th>Type</th><th class="num">Balance</th><th class="num">Rate (e.g. 0.065 = 6.5%)</th><th class="num">Monthly payment</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var l in plan.Liabilities)
                {
                    <tr>
                        <td data-label="Name"><input class="form-control form-control-sm" @bind="l.Name" /></td>
                        <td data-label="Type">
                            <select class="form-select form-select-sm" @bind="l.Type">
                                @foreach (var t in Enum.GetValues<LiabilityType>())
                                {
                                    <option value="@t">@Humanize(t)</option>
                                }
                            </select>
                        </td>
                        <td class="num" data-label="Balance"><CurrencyInput @bind-Value="l.CurrentBalance" InputClass="form-control-sm" /></td>
                        <td class="num" data-label="Rate (e.g. 0.065 = 6.5%)"><input type="number" step="0.001" class="form-control form-control-sm" @bind="l.InterestRate" /></td>
                        <td class="num" data-label="Monthly payment"><CurrencyInput @bind-Value="l.MonthlyPayment" InputClass="form-control-sm" /></td>
                        <td data-label=""><button class="btn btn-sm btn-outline-danger" @onclick="() => plan.Liabilities.Remove(l)">Remove</button></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        <button class="btn btn-outline-secondary" style="margin-top:.75rem" @onclick="AddLiability">+ Add liability</button>
    </div>

    <div class="ef-actions">
        <button class="btn btn-primary" @onclick="Save" disabled="@(!State.CanEdit)">Save changes</button>
        @if (saved) { <span class="ef-pill good" style="align-self:center">Saved</span> }
    </div>
}

@code {
    private bool saved;

    protected override async Task OnInitializedAsync() => await State.EnsureLoadedAsync();

    private void AddAccount() => State.Plan!.Accounts.Add(new Account
    {
        Name = "New account",
        Type = AccountType.Brokerage,
        Category = AccountCategory.Investment,
        TaxTreatment = TaxTreatment.Taxable
    });

    private void AddLiability() => State.Plan!.Liabilities.Add(new Liability
    {
        Name = "New liability",
        Type = LiabilityType.Other
    });

    private async Task Save()
    {
        await State.SaveAsync();
        saved = true;
    }

    private static bool CanAssignToChild(Account account) =>
        account.Category is AccountCategory.Education or AccountCategory.Investment;

    private static bool CanAssignToParent(Account account) =>
        account.Category == AccountCategory.Investment;

    // Explicit display order so "Other" (the catch-all) always sorts last,
    // regardless of the enum's underlying declaration order.
    private static readonly AccountCategory[] GroupDisplayOrder =
    [
        AccountCategory.Investment,
        AccountCategory.Education,
        AccountCategory.RealEstate,
        AccountCategory.Other
    ];

    private static string Humanize(AccountCategory c) => c switch
    {
        AccountCategory.RealEstate => "Real Estate",
        _ => c.ToString()
    };

    private static string Humanize(AccountType t) => t switch
    {
        AccountType.FourZeroOneK => "401(k)",
        AccountType.TraditionalIra => "Traditional IRA",
        AccountType.RothIra => "Roth IRA",
        AccountType.Brokerage => "Brokerage",
        AccountType.Hsa => "HSA",
        AccountType.FiveTwoNine => "529 plan",
        AccountType.UtmaUgma => "UTMA/UGMA",
        AccountType.EducationTrust => "Education trust",
        AccountType.BankAccount => "Bank account",
        AccountType.RealEstate => "Real estate",
        AccountType.Business => "Business",
        AccountType.TrumpAccount => "Trump Account",
        _ => t.ToString()
    };

    private static string Humanize(TaxTreatment t) => t switch
    {
        TaxTreatment.TaxDeferred => "Tax-deferred",
        TaxTreatment.TaxFree => "Tax-free",
        TaxTreatment.Taxable => "Taxable",
        _ => t.ToString()
    };

    private static string Humanize(LiabilityType t) => t switch
    {
        LiabilityType.Mortgage => "Mortgage",
        LiabilityType.StudentLoan => "Student loan",
        LiabilityType.VehicleLoan => "Vehicle loan",
        LiabilityType.CreditCard => "Credit card",
        LiabilityType.PersonalLoan => "Personal loan",
        LiabilityType.Other => "Other",
        _ => t.ToString()
    };
}
