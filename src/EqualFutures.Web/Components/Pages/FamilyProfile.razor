@page "/family"
@attribute [Authorize]
@rendermode InteractiveServer
@inject PlanState State

<PageTitle>Family Profile · EqualFutures</PageTitle>

<div class="ef-page-header">
    <h1>Family Profile</h1>
    <p>Tell us about the parents and children. Everything else builds on this.</p>
</div>

@if (!State.IsLoaded)
{
    <p>Loading…</p>
}
else
{
    var plan = State.Plan!;

    @if (!State.CanEdit)
    {
        <div class="ef-rec info" style="margin-bottom:1rem">
            <div class="rec-title">Read-only access</div>
            <div class="rec-detail">You can view this family's plan but not make changes. Ask the plan owner for edit access.</div>
        </div>
    }

    <div class="ef-card" style="margin-bottom:1rem">
        <div class="ef-field" style="max-width:420px">
            <label>Household name</label>
            <input class="form-control" @bind="plan.HouseholdName" disabled="@(!State.CanEdit)" />
        </div>
        <div class="ef-field" style="max-width:420px">
            <label>Household retirement spending / yr</label>
            <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" class="form-control" @bind="plan.ExpectedAnnualRetirementSpending" disabled="@(!State.CanEdit)" />
            </div>
        </div>
        @if (State.CanEdit)
        {
            <div class="ef-actions">
                @if (State.IsEmpty)
                {
                    <button class="btn btn-outline-secondary" @onclick="LoadSample" disabled="@busy">
                        @(busy ? "Loading…" : "Load sample data")
                    </button>
                }
                else if (!confirmingClear)
                {
                    <button class="btn btn-outline-danger" @onclick="() => confirmingClear = true" disabled="@busy">Clear all data</button>
                }
                else
                {
                    <span style="align-self:center">Remove all people, accounts, and liabilities?</span>
                    <button class="btn btn-danger" @onclick="ClearData" disabled="@busy">Yes, clear everything</button>
                    <button class="btn btn-outline-secondary" @onclick="() => confirmingClear = false" disabled="@busy">Cancel</button>
                }
            </div>
        }
    </div>

    <div class="ef-card" style="margin-bottom:1rem">
        <h2>Parents</h2>
        @foreach (var p in plan.Parents)
        {
            <div class="ef-grid ef-grid-4 ef-edit-row">
                <div class="ef-field"><label>Name</label><input class="form-control" @bind="p.Name" /></div>
                <div class="ef-field"><label>Current age</label><input type="number" class="form-control" @bind="p.CurrentAge" /></div>
                <div class="ef-field"><label>Retirement age</label><input type="number" class="form-control" @bind="p.PlannedRetirementAge" /></div>
                <div class="ef-field"><label>Annual income</label><div class="input-group"><span class="input-group-text">$</span><input type="number" class="form-control" @bind="p.AnnualIncome" /></div></div>
                <div class="ef-field"><label>Social Security / yr</label><div class="input-group"><span class="input-group-text">$</span><input type="number" class="form-control" @bind="p.EstimatedAnnualSocialSecurity" /></div></div>
                <div class="ef-field"><label>Pension / yr</label><div class="input-group"><span class="input-group-text">$</span><input type="number" class="form-control" @bind="p.AnnualPensionIncome" /></div></div>
                <div class="ef-field">
                    <button class="btn btn-outline-danger" @onclick="() => RemoveParent(p)" disabled="@(!State.CanEdit)">Remove</button>
                </div>
            </div>
        }
        <button class="btn btn-outline-secondary" @onclick="AddParent" disabled="@(!State.CanEdit)">+ Add parent</button>
    </div>

    <div class="ef-card" style="margin-bottom:1rem">
        <h2>Children</h2>
        @foreach (var c in plan.Children)
        {
            <div class="ef-grid ef-grid-4 ef-edit-row">
                <div class="ef-field"><label>Name</label><input class="form-control" @bind="c.Name" /></div>
                <div class="ef-field"><label>Birth date</label><input type="date" class="form-control" @bind="c.BirthDate" /></div>
                <div class="ef-field"><label>College start year</label><input type="number" class="form-control" @bind="c.ExpectedCollegeStartYear" /></div>
                <div class="ef-field"><label>Years of college</label><input type="number" class="form-control" @bind="c.YearsOfCollege" /></div>
                <div class="ef-field">
                    <label>College type</label>
                    <select class="form-select" @bind="c.CollegeType">
                        @foreach (var t in Enum.GetValues<CollegeType>())
                        {
                            <option value="@t">@Humanize(t)</option>
                        }
                    </select>
                </div>
                <div class="ef-field"><label>Family share to fund (1.00 = 100%)</label><input type="number" min="0" step="0.05" placeholder="1.00" class="form-control" @bind="c.DesiredFundingPercent" /></div>
                <div class="ef-field"><label>Scholarships / yr</label><div class="input-group"><span class="input-group-text">$</span><input type="number" class="form-control" @bind="c.ExpectedAnnualScholarships" /></div></div>
                <div class="ef-field">
                    <button class="btn btn-outline-danger" @onclick="() => RemoveChild(c)" disabled="@(!State.CanEdit)">Remove</button>
                </div>
            </div>
        }
        <button class="btn btn-outline-secondary" @onclick="AddChild" disabled="@(!State.CanEdit)">+ Add child</button>
    </div>

    <div class="ef-actions">
        <button class="btn btn-primary" @onclick="Save" disabled="@(!State.CanEdit)">Save changes</button>
        @if (saved)
        {
            <span class="ef-pill good" style="align-self:center">Saved</span>
        }
    </div>
}

@code {
    private bool saved;
    private bool busy;
    private bool confirmingClear;

    protected override async Task OnInitializedAsync() => await State.EnsureLoadedAsync();

    private async Task LoadSample()
    {
        busy = true;
        await State.LoadSampleDataAsync();
        busy = false;
        saved = false;
    }

    private async Task ClearData()
    {
        busy = true;
        await State.ClearDataAsync();
        confirmingClear = false;
        busy = false;
        saved = false;
    }

    private void AddParent() => State.Plan!.Parents.Add(new Parent { Name = "New parent", CurrentAge = 40, PlannedRetirementAge = 65 });
    private void RemoveParent(Parent p) => State.Plan!.Parents.Remove(p);

    private void AddChild()
    {
        int year = DateTime.UtcNow.Year;
        State.Plan!.Children.Add(new Child
        {
            Name = "New child",
            BirthDate = new DateOnly(year - 5, 1, 1),
            ExpectedCollegeStartYear = year + 13,
            YearsOfCollege = 4,
            DesiredFundingPercent = 1.0m
        });
    }
    private void RemoveChild(Child c) => State.Plan!.Children.Remove(c);

    private async Task Save()
    {
        await State.SaveAsync();
        saved = true;
    }

    private static string Humanize(CollegeType t) => t switch
    {
        CollegeType.PublicUniversity => "Public university",
        CollegeType.PrivateUniversity => "Private university",
        CollegeType.TradeSchool => "Trade school",
        CollegeType.NoCollege => "No college",
        CollegeType.GraduateSchool => "Graduate school",
        _ => t.ToString()
    };
}
